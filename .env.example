# minion_hub/.env.example — secret var NAMES expected by this subproject.
# DO NOT commit real values here.
#
# Resolution (6-layer, per @minion-stack/env):
# 1. AI/.env.defaults                      (meta-repo root, non-secret)
# 2. Infisical project minion-core         (cross-cutting non-subproject secrets)
# 3. minion_hub/.env.defaults              (this subproject, non-secret)
# 4. Infisical project minion-hub          (this subproject's secrets)
# 5. minion_hub/.env.local                 (gitignored local override)
# 6. shell process.env                     (wins all)
#
# Run `minion sync-env hub` to materialize layers 1-4 into .env.local.
# Run `minion doctor` to validate every name below resolves.

TURSO_DB_URL=libsql://your-db-name.region.turso.io
TURSO_DB_AUTH_TOKEN=your-auth-token-here

# Turso→Supabase cutover kill-switch (Track A2). Gateway-token auth and the
# system gateway-RPC credential read Supabase first and fall back to the legacy
# Turso `servers` table during the bake. Set to "false" to go Supabase-only once
# the Supabase `gateway` path is proven in prod; unset/anything else keeps the
# fallback. Removed entirely in Track C.
GATEWAY_TURSO_FALLBACK=

B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET_NAME=minionhub

SEED_ADMIN_EMAIL=admin@minion.hub
SEED_ADMIN_PASSWORD=changeme
SEED_TENANT_NAME=Default

# Optional: AES-256-GCM encryption key for server tokens at rest
# Falls back to a deterministic dev key if not set
ENCRYPTION_KEY=

# Optional: GitHub PAT (needs `repo` scope for bug reporting + marketplace sync)
GITHUB_TOKEN=

# Optional: GitHub repo for bug report issues (owner/repo format)
GITHUB_BUG_REPO=NikolasP98/minion_hub

# Better Auth
BETTER_AUTH_SECRET=<random-32-plus-char-string>
BETTER_AUTH_URL=http://localhost:5173

# Gateway JWT (S5: standalone jose keypair, decoupled from Better Auth).
# Issuer the gateway's oidcIssuers validates against — defaults to BETTER_AUTH_URL
# (keep stable; must equal the origin serving /.well-known/openid-configuration).
GATEWAY_JWT_ISSUER=
# Set to "false" once Better Auth's jwks table is gone (S7) to stop including the
# legacy public keys in /.well-known/jwks.json. The signing key itself lives in
# Supabase `gateway_signing_keys`, sealed with ENCRYPTION_KEY (above).
GATEWAY_JWT_INCLUDE_LEGACY_JWKS=

# Google OAuth (optional — remove if not using Google sign-in)
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: http://localhost:5173/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Client-side Better Auth URL (must be prefixed VITE_)
VITE_BETTER_AUTH_URL=http://localhost:5173

# Resend (optional — email invitations)
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Minion Hub <noreply@minion-ai.org>

# Set to "true" to skip all authentication checks (for CI / test environments)
AUTH_DISABLED=false

# OpenRouter API Key (for Image Studio + Builder AI)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Supabase (Phase 1b dual-mode auth). Hub default = supabase (cloud);
# set both to 'better-auth' to run the self-hosted fallback.
AUTH_PROVIDER=supabase               # 'supabase' | 'better-auth'
PUBLIC_AUTH_PROVIDER=supabase
PUBLIC_SUPABASE_URL=https://gxvsaskbohavnurfvshr.supabase.co
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LangGraph flow runner (langgraph-server) — used by the flow editor "Run" button
PUBLIC_LANGGRAPH_FLOWS_URL=http://localhost:2025

# Plugin UI asset origin override. Unset (default) → plugin iframe assets load
# from the gateway (current behavior). Set to a public CDN/edge host (e.g.
# https://plugin-cdn.minion-ai.org) to serve plugin dist decoupled from the
# gateway WS. Must serve the same /plugins/<id>/ui/<subpath> paths and set its
# own CSP `frame-ancestors`. Only affects asset loading + postMessage origin;
# the gateway WebSocket is unaffected. See
# specs/2026-06-14-plugin-ui-cdn-caching-design.md.
# PUBLIC_PLUGIN_UI_BASE_URL=

# Shared secret for langgraph-server → hub internal API (/api/internal/flows/*)
HUB_API_TOKEN=
