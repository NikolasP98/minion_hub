  "scripts": {
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 vite dev",
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vite build",
    "vercel-build": "([ -f .env ] || cp .env.example .env) && bun scripts/db-migrate.ts && bun run build",
    "db:migrate": "bun scripts/db-migrate.ts",
    "db:status": "bun scripts/db-status.ts",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:design": "node scripts/design-lint.mjs",
    "lint:design:ci": "node scripts/design-lint.mjs --ci",
    "lint:tokens": "node scripts/token-integrity.mjs",
    "lint:tokens:ci": "node scripts/token-integrity.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit:ui:inventory": "node scripts/ui-audit-inventory.mjs",
    "audit:ui:seed": "bun scripts/ui-audit-seed.ts",
    "audit:ui:capture": "E2E_UI_AUDIT=1 playwright test tests/e2e/ui-audit/route-audit.spec.ts",
    "audit:ui:certify": "E2E_UI_AUDIT=1 E2E_UI_AUDIT_CERTIFY=1 playwright test tests/e2e/ui-audit/route-audit.spec.ts",
    "desktop:build": "DESKTOP=1 VITE_DESKTOP=1 vite build",
    "desktop:serve": "DESKTOP=1 VITE_DESKTOP=1 PORT=5959 ORIGIN=http://localhost:5959 HOST=127.0.0.1 BETTER_AUTH_URL=http://localhost:5959 TURSO_DB_URL=file:./data/minion_hub.db SSRF_ALLOWED_HOSTNAME_SUFFIXES=localhost,127.0.0.1,.ts.net SSRF_ALLOW_TAILSCALE_CGNAT=true node --env-file-if-exists=.env build/index.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "type": "module",
  "prettier": "@minion-stack/lint-config/prettier.config.cjs"
