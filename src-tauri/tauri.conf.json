{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minion Hub",
  "version": "0.0.1",
  "identifier": "app.minionhub.desktop",
  "build": {
    "frontendDist": "../src-tauri/loading-dist",
    "devUrl": "http://localhost:5959",
    "beforeDevCommand": "bun run desktop:serve",
    "beforeBuildCommand": "bun run desktop:build"
  },
  "app": {
    "windows": [
      {
        "title": "Minion Hub",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Minion Hub desktop",
    "longDescription": "Self-hosted desktop frontend for the Minion AI agent gateway."
  },
  "plugins": {}
}
